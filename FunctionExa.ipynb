     "text": [
      "1000\n"
     ]
    }
   ],
   "source": [
    "def large(a, b, c):\n",
    "    if a >= b and a >= c:\n",
    "        return a\n",
    "    elif b >= a and b >= c:\n",
    "        return b\n",
    "    else:\n",
    "        return c\n",
    "\n",
    "print(large(10, 100, 1000))"
   ]
